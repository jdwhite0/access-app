{
  "$id": "https://jd-ai-systems.dev/schemas/blueprint.schema.mvp.json",
  "title": "Founder Blueprint MVP",
  "description": "Portable founder ecosystem specification. Canonical truth lives in ACCESS after save; this file is an export snapshot.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "blueprint_id",
    "blueprint_version",
    "status",
    "founder",
    "organizations",
    "products",
    "experiences",
    "output"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0-mvp"
    },
    "blueprint_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "blueprint_version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "exported", "materialized"]
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "access_blueprint_id": {
      "type": "string",
      "format": "uuid"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "origination": {
          "type": "string",
          "enum": ["access_wizard", "jyson_import", "manual", "unknown"]
        },
        "authority": {
          "type": "string",
          "enum": ["canonical", "draft"]
        },
        "draft": { "type": "boolean" }
      }
    },
    "founder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "access_handle"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "access_handle": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*\\.access$"
        }
      }
    },
    "organizations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "name": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "name": { "type": "string", "minLength": 1, "maxLength": 256 },
          "type": { "type": "string", "enum": ["platform", "portfolio"] },
          "organization_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          }
        }
      }
    },
    "experiences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "url"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "name": { "type": "string", "minLength": 1, "maxLength": 256 },
          "url": { "type": "string", "format": "uri" },
          "product_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["founder_os_id", "name"],
      "properties": {
        "founder_os_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    }
  }
}
