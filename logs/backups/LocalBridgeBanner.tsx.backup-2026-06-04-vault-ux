'use client'

import { useCallback, useEffect, useState } from 'react'
import { DEV_FOUNDER_CMD } from '@/lib/openjarvis/founder-setup'

type BridgeStatus = {
  bridgeOnline: boolean
  localDev: boolean
  canSyncWithoutBridge: boolean
  userMessage: string
  startCommand: string
  devicePaired: boolean
}

const POLL_MS = 8000

export function LocalBridgeBanner() {
  const [status, setStatus] = useState<BridgeStatus | null>(null)
  const [copied, setCopied] = useState(false)

  const load = useCallback(async () => {
    try {
      const res = await fetch('/api/vault/local-bridge-status', { cache: 'no-store' })
      if (!res.ok) return
      const json = (await res.json()) as BridgeStatus
      setStatus(json)
    } catch {
      /* ignore poll errors */
    }
  }, [])

  useEffect(() => {
    void load()
    const id = window.setInterval(() => void load(), POLL_MS)
    return () => window.clearInterval(id)
  }, [load])

  async function copyStartCommand() {
    const cmd = status?.startCommand ?? DEV_FOUNDER_CMD
    try {
      await navigator.clipboard.writeText(cmd)
      setCopied(true)
      window.setTimeout(() => setCopied(false), 2000)
    } catch {
      setCopied(false)
    }
  }

  if (!status) return null

  const tone = status.bridgeOnline
    ? 'operational'
    : status.localDev
      ? 'neutral'
      : 'warning'

  return (
    <div className={`access-vault-bridge-banner access-vault-bridge-banner--${tone}`}>
      <div className="access-vault-bridge-banner__main">
        <p className="access-vault-bridge-banner__title">
          {status.bridgeOnline ? 'Local bridge: connected' : 'Local bridge: offline'}
        </p>
        <p className="access-vault-bridge-banner__body">{status.userMessage}</p>
        {!status.bridgeOnline && status.localDev && (
          <p className="access-vault-bridge-banner__hint">
            Keep ACCESS running on this Mac. One terminal: <code>{status.startCommand}</code> starts the app,
            OpenJarvis, and the bridge heartbeat.
          </p>
        )}
      </div>
      {!status.bridgeOnline && (
        <button
          type="button"
          className="access-platform-primary-btn access-vault-bridge-banner__btn"
          onClick={() => void copyStartCommand()}
        >
          {copied ? 'Copied' : 'Copy start command'}
        </button>
      )}
    </div>
  )
}
