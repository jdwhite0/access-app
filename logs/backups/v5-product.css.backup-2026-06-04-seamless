/**
 * ACCESS V5 — capability-first product surfaces
 */

/* ── Vault page ────────────────────────────────────────────────────────────── */

.access-vault-security-notice {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  background: var(--info-muted, rgba(64,192,208,0.06));
  border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
  border-radius: var(--app-radius, 8px);
  font-size: 0.8125rem;
  color: var(--text-dim);
  line-height: 1.5;
  margin-bottom: 4px;
}

.access-vault-security-notice__icon {
  font-size: 14px;
  flex-shrink: 0;
  margin-top: 1px;
}

.access-vault-sync-feedback {
  padding: 10px 14px;
  background: var(--success-muted);
  border: 1px solid color-mix(in srgb, var(--success) 30%, transparent);
  border-radius: var(--app-radius, 8px);
  font-size: 0.8125rem;
  color: var(--success);
  margin-bottom: 4px;
}

.access-vault-bridge-banner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  padding: 12px 14px;
  border-radius: var(--app-radius, 8px);
  margin-bottom: 8px;
  border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
  background: var(--info-muted, rgba(64, 192, 208, 0.06));
}

.access-vault-bridge-banner--operational {
  border-color: color-mix(in srgb, var(--success) 35%, transparent);
  background: var(--success-muted);
}

.access-vault-bridge-banner--warning {
  border-color: color-mix(in srgb, var(--warning, #e8b84a) 40%, transparent);
  background: color-mix(in srgb, var(--warning, #e8b84a) 8%, transparent);
}

.access-vault-bridge-banner__title {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text);
  margin: 0 0 4px;
}

.access-vault-bridge-banner__body,
.access-vault-bridge-banner__hint {
  font-size: 0.8125rem;
  color: var(--text-dim);
  line-height: 1.5;
  margin: 0;
}

.access-vault-bridge-banner__hint {
  margin-top: 6px;
}

.access-vault-bridge-banner__btn {
  flex-shrink: 0;
  align-self: center;
}

/* ── Vault card ────────────────────────────────────────────────────────────── */

.access-vault-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.access-vault-card {
  background: var(--surface-raised, var(--surface));
  border: 1px solid var(--border);
  border-radius: var(--app-radius, 8px);
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.access-vault-card__header {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.access-vault-card__title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.access-vault-card__name {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--text);
  margin: 0 0 3px;
}

.access-vault-card__path {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  word-break: break-all;
  margin: 0;
}

.access-vault-card__badges {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-shrink: 0;
  flex-wrap: wrap;
}

.access-vault-card__desc {
  font-size: 0.8125rem;
  color: var(--text-dim);
  line-height: 1.5;
  margin: 0;
}

.access-vault-card__meta {
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 10px 12px;
  background: color-mix(in srgb, var(--surface) 60%, transparent);
  border-radius: var(--app-radius-sm, 5px);
  border: 1px solid var(--border);
}

.access-vault-card__meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.access-vault-card__meta-value {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--text-dim);
  text-align: right;
}

.access-vault-card__sync-msg {
  font-size: 0.8125rem;
  color: var(--text-dim);
  padding: 8px 12px;
  border-radius: var(--app-radius-sm, 5px);
  background: var(--surface);
  border: 1px solid var(--border);
  line-height: 1.5;
}

.access-vault-card__actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

/* ── Registration form ─────────────────────────────────────────────────────── */

.access-vault-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  max-width: 600px;
}

.access-vault-form__header {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.access-vault-form__title {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--text);
  margin: 0;
}

.access-vault-form__note {
  font-size: 0.8125rem;
  color: var(--text-muted);
  line-height: 1.5;
  margin: 0;
}

.access-vault-form__fields {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.access-vault-form__field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.access-vault-form__label {
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--text);
}

.access-vault-form__label-note {
  font-weight: 400;
  color: var(--text-muted);
}

.access-vault-form__input {
  padding: 9px 12px;
  background: var(--surface-raised, var(--surface));
  border: 1px solid var(--border);
  border-radius: var(--app-radius-sm, 5px);
  color: var(--text);
  font-family: var(--font-sans, inherit);
  font-size: 0.9375rem;
  transition: border-color 0.15s;
  width: 100%;
}

.access-vault-form__input:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}

.access-vault-form__input--mono {
  font-family: var(--mono) !important;
  font-size: 0.8125rem !important;
}

.access-vault-form__input--textarea {
  resize: vertical;
  min-height: 80px;
  line-height: 1.55;
}

.access-vault-form__hint {
  font-size: 0.75rem;
  color: var(--text-muted);
  line-height: 1.5;
  margin: 0;
}

.access-vault-form__error {
  font-size: 0.8125rem;
  color: var(--error);
  margin: 0;
}

.access-vault-form__success {
  font-size: 0.8125rem;
  color: var(--success);
  margin: 0;
}

.access-vault-form__footer {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

/* ── Empty state ───────────────────────────────────────────────────────────── */

.access-vault-empty {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 32px 24px;
  border: 1px dashed var(--border);
  border-radius: var(--app-radius, 8px);
  background: color-mix(in srgb, var(--surface) 50%, transparent);
  text-align: center;
  align-items: center;
  max-width: 560px;
}

.access-vault-empty__title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text);
  margin: 0;
}

.access-vault-empty__body {
  font-size: 0.875rem;
  color: var(--text-dim);
  line-height: 1.6;
  margin: 0;
  max-width: 44ch;
}

.access-vault-empty__actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 4px;
}

/* ── Connector instructions ────────────────────────────────────────────────── */

.access-vault-connector-info {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.access-vault-connector-info__step {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.access-vault-connector-info__num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--accent-glow);
  border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--accent);
  flex-shrink: 0;
  margin-top: 2px;
}

.access-vault-connector-info code {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--accent);
  background: var(--accent-glow);
  padding: 1px 5px;
  border-radius: 3px;
}

/* ── Prompt suggestions ────────────────────────────────────────────────────── */

.access-vault-suggestions {
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
}

/* ── Light mode ────────────────────────────────────────────────────────────── */

html[data-theme='day'] .access-vault-card {
  background: #ffffff;
  border-color: #e6ebf1;
  box-shadow: 0 1px 3px rgba(10,37,64,0.05);
}

html[data-theme='day'] .access-vault-card__meta {
  background: #f6f9fc;
  border-color: #e6ebf1;
}

html[data-theme='day'] .access-vault-form__input {
  background: #ffffff;
  border-color: #e6ebf1;
  color: #0a2540;
}

html[data-theme='day'] .access-vault-form__input:focus {
  border-color: #1a8fa0;
  box-shadow: 0 0 0 3px rgba(26,143,160,0.1);
}

html[data-theme='day'] .access-vault-security-notice {
  background: rgba(26,143,160,0.06);
  border-color: rgba(26,143,160,0.2);
  color: #425466;
}

html[data-theme='day'] .access-vault-sync-feedback {
  background: rgba(45,138,110,0.08);
  border-color: rgba(45,138,110,0.25);
  color: #2d8a6e;
}

html[data-theme='day'] .access-vault-connector-info__num {
  background: rgba(26,143,160,0.08);
  border-color: rgba(26,143,160,0.25);
  color: #1a8fa0;
}

html[data-theme='day'] .access-vault-connector-info code {
  color: #1a8fa0;
  background: rgba(26,143,160,0.08);
}

/* ── Mobile ────────────────────────────────────────────────────────────────── */

@media (max-width: 768px) {
  .access-vault-card__title-row {
    flex-direction: column;
  }

  .access-vault-card__badges {
    flex-shrink: unset;
  }

  .access-vault-form {
    max-width: 100%;
  }

  .access-vault-empty__actions {
    flex-direction: column;
    width: 100%;
  }

  .access-vault-empty__actions > * {
    width: 100%;
    text-align: center;
  }
}

.access-workspace-snapshot {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 10px;
  padding: 14px 16px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 92%, transparent);
}

.access-workspace-snapshot__row {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.access-workspace-snapshot__label {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.access-workspace-snapshot__value {
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--text);
}

.access-home-recommendations {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.access-home-recommendations__item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 88%, transparent);
  font-size: 0.875rem;
  color: var(--text-dim);
}

.access-home-focus {
  font-size: 1.0625rem;
  line-height: 1.5;
  color: var(--text-dim);
  max-width: 42rem;
}

.access-capability-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

.access-capability-row:last-child {
  border-bottom: none;
}

.access-plans-leverage {
  max-width: 960px;
  margin: 0 auto;
  padding: 48px 24px 80px;
}

.access-plans-leverage__tier {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 24px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, transparent);
}

.access-plans-leverage__tier--featured {
  border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
  box-shadow: 0 8px 32px color-mix(in srgb, var(--accent) 8%, transparent);
}

.access-plans-leverage__transform {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.35;
}

.access-plans-leverage__leverage {
  font-size: 0.875rem;
  line-height: 1.55;
  color: var(--text-dim);
}

.access-project-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}
